// 1. Cấu hình công cụ
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Bảng 1: Người dùng
model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String 
  role         Role         @default(STUDENT)
  vocabularies Vocabulary[]
  decks        Deck[]       
  createdAt    DateTime     @default(now())
}

enum Role {
  ADMIN
  STUDENT
}

// BẢNG MỚI: Đề thi (Nhóm bài học)
model Exam {
  id        String     @id @default(cuid())
  title     String     
  type      CourseType 
  lessons   Lesson[]   
  createdAt DateTime   @default(now())

  @@index([createdAt(sort: Desc)])
}

// Bảng 2: Bài học
model Lesson {
  id        String     @id @default(cuid())
  title     String     
  content   String     
  type      CourseType 
  category  String     
  
  examId    String?    
  exam      Exam?      @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  createdAt DateTime   @default(now())

  @@index([createdAt(sort: Desc)])
}

enum CourseType {
  IELTS
  HSG
}

// Bảng 3: Nhóm từ vựng (Deck)
model Deck {
  id           String       @id @default(cuid())
  name         String
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  vocabularies Vocabulary[]
  createdAt    DateTime     @default(now())

  @@index([userId])
}

// Bảng 4: Từ vựng
model Vocabulary {
  id        String   @id @default(cuid())
  word      String   
  meaning   String   
  ipa       String?  
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  deckId    String?  
  deck      Deck?    @relation(fields: [deckId], references: [id]) 
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}