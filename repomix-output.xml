          </Link>
          <h1 className="text-4xl font-bold flex items-center gap-3 text-zinc-900">
            <Database className="w-8 h-8" /> Quản lý Kho Từ
          </h1>
        </div>
      </header>

      {/* Truyền data sang Client Component để xử lý logic Checkbox */}
