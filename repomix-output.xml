// 1. Cấu hình công cụ
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Bảng 1: Người dùng
model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String 
  role         Role         @default(STUDENT)
  vocabularies Vocabulary[]
  decks        Deck[]       // Mối quan hệ: User tạo nhiều Decks
  createdAt    DateTime     @default(now())
}

enum Role {
  ADMIN
  STUDENT
}

// Bảng 2: Bài học
model Lesson {
  id        String     @id @default(cuid())
  title     String     
  content   String     
  type      CourseType 
  category  String     
  createdAt DateTime   @default(now())

  @@index([createdAt(sort: Desc)])
}

enum CourseType {
  IELTS
  HSG
}

// Bảng 3: Nhóm từ vựng (Deck)
model Deck {
  id           String       @id @default(cuid())
  name         String
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  vocabularies Vocabulary[]
  createdAt    DateTime     @default(now())

  @@index([userId])
}

// Bảng 4: Từ vựng
model Vocabulary {
  id        String   @id @default(cuid())
  word      String   
  meaning   String   
  ipa       String?  
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  // ĐÂY CHÍNH LÀ DÒNG BỊ LỖI LÚC NÃY, TAO GHI ĐẦY ĐỦ RỒI ĐÓ
  deckId    String?  
  deck      Deck?    @relation(fields: [deckId], references: [id]) 
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}
