<file path="app/page.tsx">
import { getServerSession } from 'next-auth';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import Link from 'next/link';
import { LogOut, User as UserIcon } from 'lucide-react'; // Import icon cho đẹp

export default async function HomePage() {
  // Lấy thông tin phiên đăng nhập từ Server
  const session = await getServerSession();

  return (
    <main className="min-h-screen bg-zinc-50 p-8">
      {/* Thanh điều hướng nhanh (Navbar) */}
      <div className="max-w-5xl mx-auto flex justify-end mb-6">
        {session ? (
          <div className="flex items-center gap-4">
            <div className="flex items-center gap-2 bg-white px-4 py-2 rounded-full border shadow-sm">
              <UserIcon className="size-4 text-zinc-500" />
              <span className="text-sm font-medium">Chào, {session.user?.name}</span>
            </div>
            {/* Chỗ này tí nữa làm nút Đăng xuất sau, tạm thời dùng link hoặc button */}
            <Link href="/api/auth/signout">
              <Button variant="ghost" size="sm" className="text-red-500 hover:text-red-600">
                <LogOut className="size-4 mr-2" />
                Đăng xuất
              </Button>
            </Link>
          </div>
        ) : (
          <Link href="/login">
            <Button variant="default">Đăng nhập</Button>
          </Link>
        )}
      </div>

      {/* Phần Header */}
      <div className="max-w-5xl mx-auto text-center mb-12">
        <h1 className="text-5xl font-extrabold tracking-tight text-zinc-900 mb-4">
          English Mastery Hub
        </h1>
        <p className="text-lg text-zinc-600">
          Hệ thống ôn luyện HSG & IELTS chuyên nghiệp.
        </p>
      </div>

      {/* Phần Modules */}
      <div className="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
        <Link href="/vault">
        <Card className="hover:shadow-md transition-shadow cursor-pointer">
          <CardHeader>
            <CardTitle>📚 The Vault</CardTitle>
            <CardDescription>Kho tài liệu HSG & IELTS</CardDescription>
          </CardHeader>
          <CardContent>
            <p className="text-sm text-zinc-500">
              {session ? "Bắt đầu làm bài tập ngay thôi!" : "Đăng nhập để xem tài liệu."}
            </p>
          </CardContent>
        </Card>
        </Link>
        <Card className="hover:shadow-md transition-shadow cursor-pointer">
          <CardHeader>
            <CardTitle>🗂️ Flashcards</CardTitle>
            <CardDescription>Học từ vựng thông minh</CardDescription>
          </CardHeader>
          <CardContent>
            <p className="text-sm text-zinc-500">
              Lưu trữ từ mới và ôn luyện mỗi ngày.
            </p>
          </CardContent>
        </Card>

        <Card className="hover:shadow-md transition-shadow cursor-pointer">
          <CardHeader>
            <CardTitle>📊 Analytics</CardTitle>
            <CardDescription>Bảng thành tích</CardDescription>
          </CardHeader>
          <CardContent>
            <p className="text-sm text-zinc-500">
              Theo dõi sự tiến bộ của mày và em trai.
            </p>
          </CardContent>
        </Card>
      </div>
    </main>
  );
}
