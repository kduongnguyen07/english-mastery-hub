'use server';

import { prisma } from '@/lib/prisma';
import { revalidatePath } from 'next/cache';
import { redirect } from 'next/navigation';

/**
 * Thêm bài học mới vào Database.
 * @param {FormData} formData - Dữ liệu từ form gửi lên.
 */
export async function createLesson(formData: FormData) {
  const title = formData.get('title') as string;
  const content = formData.get('content') as string;
  const type = formData.get('type') as 'IELTS' | 'HSG';
  const category = formData.get('category') as string;

  // Lưu vào Postgres thông qua Prisma
  await prisma.lesson.create({
    data: {
      title,
      content,
      type,
      category,
    },
  });

  // Làm mới bộ nhớ đệm trang chủ/danh sách để hiện bài mới ngay lập tức
  revalidatePath('/');
  redirect('/'); // Xong thì quay về trang chủ
}
export async function saveVocabulary(word: string, meaning: string) {
  const session = await getServerSession();
  
  if (!session?.user?.email) {
    throw new Error("Mày phải đăng nhập mới lưu được chứ!");
  }

  const user = await prisma.user.findUnique({
    where: { email: session.user.email }
  });

  if (!user) return;

  await prisma.vocabulary.create({
    data: {
      word,
      meaning,
      userId: user.id,
    },
  });

  revalidatePath('/flashcards');
}
</file>

