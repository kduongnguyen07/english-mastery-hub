// 1. Cấu hình công cụ
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ... các model User, Lesson, Vocabulary giữ nguyên bên dưới

// ==========================================
// THIẾT KẾ CÁC BẢNG (TABLES)
// ==========================================

// Bảng 1: Người dùng (Mày và em trai)
model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String 
  role         Role         @default(STUDENT) // Mặc định ai vào cũng là Học sinh
  vocabularies Vocabulary[] // Mối quan hệ: 1 User có nhiều Từ vựng
  createdAt    DateTime     @default(now())
}

// Phân quyền: Mày là ADMIN, em trai là STUDENT
enum Role {
  ADMIN
  STUDENT
}

// Bảng 2: Bài học (Kho tài liệu HSG & IELTS)
model Lesson {
  id        String     @id @default(cuid())
  title     String     // Tên bài học (VD: Unit 1 - Family)
  content   String     // Nội dung hoặc Link file PDF
  type      CourseType // Loại khóa học (IELTS hay HSG)
  category  String     // Phân loại (VD: Reading, Grammar, Idioms)
  createdAt DateTime   @default(now())
}

enum CourseType {
  IELTS
  HSG
}

// Bảng 3: Từ vựng (Flashcard cá nhân)
model Vocabulary {
  id        String   @id @default(cuid())
  word      String   // Từ tiếng Anh
  meaning   String   // Nghĩa tiếng Việt
  ipa       String?  // Phiên âm quốc tế (Dấu ? nghĩa là có thể để trống)
  
  // Liên kết từ vựng này thuộc về ai (Mày hay em trai)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}
</file>

</files>
